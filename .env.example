# Copier ce fichier en .env et remplir les valeurs.
# .env ne doit JAMAIS être commité (voir .gitignore).

# ─── Stockage S3 / MinIO (SSP Cloud) ────────────────────────────
# Sur Onyxia, ces variables sont souvent déjà injectées.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_ENDPOINT=minio.lab.sspcloud.fr
AWS_DEFAULT_REGION=us-east-1

# Bucket et préfixes du projet
S3_BUCKET=mon-bucket
S3_PREFIX_RAW=evaluation-ecrit/raw
S3_PREFIX_GROUND_TRUTH=evaluation-ecrit/ground_truth

# ─── Service de modèles (vLLM via llm.lab) ──────────────────────
# API compatible OpenAI. Pas de vraie clé nécessaire sur llm.lab interne,
# mettre une valeur factice si le client l'exige.
LLM_BASE_URL=https://llm.lab.sspcloud.fr/api/v1
LLM_API_KEY=dummy

# ─── Suivi d'expériences ────────────────────────────────────────
MLFLOW_TRACKING_URI=https://mlflow.lab.sspcloud.fr
LANGFUSE_HOST=https://langfuse.lab.sspcloud.fr
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
